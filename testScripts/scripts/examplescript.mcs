package example:test;

class Main {
    class Test {
        string field;

        constructor(){
            field = "Test";
        }
    }
    static Test foo() {
        summon("breeze_wind_charge","~ ~ ~","");
        summon("breeze_wind_charge","~ ~ ~","");
        for (int i = 0; i< 10; i++){
            print($"Hi i is ${i}");
        }
        print("Hi");

        Test test = new Test();
        print(test.field);
        return test;
    }
    function init(){
        foo();
    }
}